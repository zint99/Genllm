#version 460

#extension GL_EXT_shader_explicit_arithmetic_types : enable

const uint TILE = 16;

layout(local_size_x = TILE, local_size_y = TILE, local_size_z = 1) in;

layout(push_constant) uniform Params {
    int B;
    int M;
    int N;
    int K;
    int has_bias;
    int transpose_w;
} p;

layout(std430, binding = 0) readonly buffer SrcX    { float x[]; };
layout(std430, binding = 1) readonly buffer SrcW    { float w[]; };
layout(std430, binding = 2) readonly buffer SrcBias { float bias_data[]; };
layout(std430, binding = 3) buffer       Dst       { float dst[]; };

shared float sh_x[TILE][TILE];
shared float sh_w[TILE][TILE];

void main() {
    uint batch = gl_WorkGroupID.z;
    uint tile_m = gl_WorkGroupID.y;
    uint tile_n = gl_WorkGroupID.x;

    uint lr = gl_LocalInvocationID.y;
    uint lc = gl_LocalInvocationID.x;

    uint row = tile_m * TILE + lr;
    uint col = tile_n * TILE + lc;

    uint off_x = batch * p.M * p.K;
    uint off_o = batch * p.M * p.N;

    float acc = 0.0;

    for (uint kt = 0; kt < p.K; kt += TILE) {
        uint x_r = row;
        uint x_c = kt + lc;
        sh_x[lr][lc] = (x_r < p.M && x_c < p.K)
            ? x[off_x + x_r * p.K + x_c]
            : 0.0;

        uint w_r = kt + lr;
        uint w_c = col;
        if (w_r < p.K && w_c < p.N) {
            sh_w[lr][lc] = (p.transpose_w != 0)
                ? w[w_c * p.K + w_r]
                : w[w_r * p.N + w_c];
        } else {
            sh_w[lr][lc] = 0.0;
        }

        barrier();
        memoryBarrierShared();

        for (uint k = 0; k < TILE; ++k) {
            acc += sh_x[lr][k] * sh_w[k][lc];
        }

        barrier();
    }

    if (row < p.M && col < p.N) {
        float r = acc;
        if (p.has_bias != 0) {
            r += bias_data[col];
        }
        dst[off_o + row * p.N + col] = r;
    }
}
