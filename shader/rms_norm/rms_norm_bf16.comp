#version 460
#extension GL_EXT_bfloat16 : enable                   // 支持 bfloat16_t 类型
#extension GL_KHR_shader_subgroup_basic : enable
#extension GL_KHR_shader_subgroup_ballot : enable
#extension GL_KHR_shader_subgroup_shuffle_relative : enable
#extension GL_EXT_shader_explicit_arithmetic_types : enable // 提供 subgroupShuffleDown 等函数
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : enable

layout(local_size_x = 256) in;

layout(push_constant) uniform Params {
    int rows;
    int hidden_size;
    float eps;
} params;

layout(std430, binding = 0) readonly buffer Src0 { 
    bfloat16_t input_x[];  // 输入 x，形状 [rows, hidden_size]
};
layout(std430, binding = 1) readonly buffer Src1 { 
    float weight[];  // 权重 weight，长度 hidden_size
};
layout(std430, binding = 2) writeonly buffer Dst {
    bfloat16_t dst_data[];        // 输出 output，形状 [rows, hidden_size]
};

void main() {
    uint warp_id = gl_SubgroupID;           // 对应 warp_id
    uint lane_id = gl_SubgroupInvocationID; // 对应 lane_id

    uint row = gl_WorkGroupID.x * (gl_WorkGroupSize.x / gl_SubgroupSize) + warp_id;

    if (row >= uint(params.rows)) return;

    // 行基址计算
    int row_offset = int(row) * params.hidden_size;

    float sum = 0.0f;
    for (int i = int(lane_id); i < params.hidden_size; i += int(gl_SubgroupSize)) {
        float v = float(input_x[row_offset + i]);   // bfloat16_t -> float
        sum += v * v;
    }

    #pragma unroll
    for (uint offset = gl_SubgroupSize / 2; offset > 0; offset /= 2) {
        sum += subgroupShuffleDown(sum, offset);
    }

    float total_sum = subgroupBroadcast(sum, 0);
    float mean_sq   = total_sum / float(params.hidden_size);
    float inv_rms   = inversesqrt(mean_sq + params.eps);

    for (int i = int(lane_id); i < params.hidden_size; i += int(gl_SubgroupSize)) {
        float v = float(input_x[row_offset + i]);
        float o = v * inv_rms * weight[i];
        dst_data[row_offset + i] = bfloat16_t(o);
    }
}